package pages

import (
	"context"
	"fmt"
	"shs/actions"
	"shs/app/models"
	"shs/handlers/middlewares/webi18n"
	"shs/web/i18n"
	"shs/web/views/components"
	"strconv"
)

func permissionText(ctx context.Context, permissionType, resourceName string) string {
	localeKey, _ := ctx.Value(webi18n.LocaleKey).(string)
	if localeKey == "en" {
		return fmt.Sprintf("%s %s %s", permissionType, i18n.Strings("en").On, resourceName)
	}

	return fmt.Sprintf("%s %s", permissionType, resourceName)
}

